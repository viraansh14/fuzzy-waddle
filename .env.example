# Polymarket CLOB API
POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_API_SECRET=your_api_secret_here
POLYMARKET_API_PASSPHRASE=your_passphrase_here
POLYMARKET_PRIVATE_KEY=your_polygon_wallet_private_key_here

# Optional: Override endpoints
CLOB_API_URL=https://clob.polymarket.com
GAMMA_API_URL=https://gamma-api.polymarket.com

# Risk Management
MAX_POSITION_SIZE_USDC=100
MAX_TOTAL_EXPOSURE_USDC=500
MAX_POSITIONS=10
STOP_LOSS_PCT=15
TAKE_PROFIT_PCT=40

# Bot Settings
TRADE_LOOP_INTERVAL_SECONDS=60
MIN_LIQUIDITY_USDC=1000
MIN_VOLUME_USDC=5000
DRY_RUN=true

# News/Sentiment API (optional - for sentiment strategy)
NEWS_API_KEY=your_newsapi_key_here
